canvas {
  size 1920x1080
  fps 60
  duration 61s
  background #050608
}

camera {
  zoom 1
  x 0
  y 0
  rotation 0
  cameraAnimation speedZoom(delay 20.3s duration 1.1s from 1 peak 1.08 to 1.015 xPeak -20 yPeak 8 ease power3.out)
}

import "/video-motion/assets/motionly/motionly-logo.svg" as motionlyLogo
import "/video-motion/assets/motionly/motionly-logo.svg" as finalLogo
import "/video-motion/assets/motionly/file.svg" as sourceFile
import "/video-motion/assets/motionly/code.svg" as codeIcon
import "/video-motion/assets/motionly/code-window.svg" as editorWindow
import "/video-motion/assets/motionly/code-window.svg" as refineWindow
import "/video-motion/assets/motionly/render-frame.svg" as renderFrame
import "/video-motion/assets/motionly/motion.svg" as motionCurve
import "/video-motion/assets/motionly/play.svg" as playIcon
import "/video-motion/assets/motionly/export.svg" as exportIcon
import "/video-motion/assets/motionly/claude-code-color.svg" as claudeCode
import "/video-motion/assets/motionly/codex-color.svg" as codex
import "/video-motion/assets/motionly/antigravity-color.svg" as antigravity

overlay brandScene {
  layer background
  fill #09111d
  opacity 0
  animation shapeWipe(delay 7.15s duration 850ms direction right ease power3.out)
}

overlay sourceScene {
  layer background
  fill #07130f
  opacity 0
  animation shapeWipe(delay 14.35s duration 800ms direction up ease power3.out)
}

overlay editorScene {
  layer background
  fill #0b0e13
  opacity 0
  animation shapeWipe(delay 20.25s duration 780ms direction left ease power3.out)
}

overlay showcaseScene {
  layer background
  fill #121016
  opacity 0
  animation shapeWipe(delay 23.5s duration 800ms direction down ease power3.out)
}

overlay aiScene {
  layer background
  fill #090d12
  opacity 0
  animation irisWipe(delay 31.35s duration 850ms ease power3.out)
}

overlay refineScene {
  layer background
  fill #07130f
  opacity 0
  animation shapeWipe(delay 42.25s duration 780ms direction right ease power3.out)
}

overlay controlScene {
  layer background
  fill #11100d
  opacity 0
  animation shapeWipe(delay 46.55s duration 800ms direction up ease power3.out)
}

overlay endScene {
  layer background
  fill #050608
  opacity 0
  animation irisWipe(delay 53.8s duration 850ms ease power3.out)
}

overlay atmosphere {
  layer background
  opacity 0
  backgroundEffect aurora(duration 61s opacity .18 intensity .55)
}

overlay fade {
  layer effects
  fill #050608
  opacity 1
}

motionlyLogo {
  center
  layer hero
  width 220
  x -470
  y -34
  opacity 0
  scale 1
  shadow 36
  animation maskReveal(delay 7.45s duration 900ms direction down exitAt 14.2s exitDuration 500ms ease power3.out)
}

sourceFile {
  center
  layer hero
  width 280
  x -410
  y 24
  opacity 0
  scale 1
  shadow 34
  animation dynamicSlide(delay 14.65s duration 850ms direction right distance 170 exitAt 20.15s exitDuration 500ms ease power3.out)
}

codeIcon {
  center
  layer supporting
  width 210
  x -140
  y 144
  opacity 0
  scale 1
  shadow 24
  animation dynamicSlide(delay 17.8s duration 720ms direction up distance 100 exitAt 20.1s exitDuration 480ms ease power3.out)
}

editorWindow {
  center
  layer hero
  width 980
  y 72
  opacity 0
  scale 1
  rotation .6
  shadow 46
  animation maskReveal(delay 20.55s duration 900ms direction right exitAt 23.45s exitDuration 500ms ease power3.out)
}

renderFrame {
  center
  layer hero
  width 720
  x -450
  y 46
  opacity 0
  scale 1
  rotation -1
  shadow 42
  animation maskReveal(delay 23.8s duration 850ms direction right exitAt 31.2s exitDuration 500ms ease power3.out)
}

motionCurve {
  center
  layer supporting
  width 210
  x 470
  y 112
  opacity 0
  scale 1
  shadow 22
  animation dynamicSlide(delay 26.8s duration 650ms direction up distance 80 exitAt 31.2s exitDuration 450ms ease power3.out)
}

playIcon {
  center
  layer supporting
  width 145
  x 690
  y 112
  opacity 0
  scale 1
  shadow 20
  animation dynamicSlide(delay 27.15s duration 650ms direction up distance 80 exitAt 31.2s exitDuration 450ms ease power3.out)
}

claudeCode {
  center
  layer hero
  width 160
  x -310
  y 32
  opacity 0
  scale 1
  shadow 28
  animation dynamicSlide(delay 37.65s duration 700ms direction up distance 90 exitAt 42.05s exitDuration 450ms ease power3.out)
}

codex {
  center
  layer hero
  width 160
  y 32
  opacity 0
  scale 1
  shadow 28
  animation dynamicSlide(delay 38.9s duration 700ms direction up distance 90 exitAt 42.05s exitDuration 450ms ease power3.out)
}

antigravity {
  center
  layer hero
  width 160
  x 310
  y 32
  opacity 0
  scale 1
  shadow 28
  animation dynamicSlide(delay 39.78s duration 700ms direction up distance 90 exitAt 42.05s exitDuration 450ms ease power3.out)
}

refineWindow {
  center
  layer hero
  width 900
  x 330
  y 54
  opacity 0
  scale 1
  rotation .5
  shadow 44
  animation maskReveal(delay 42.55s duration 850ms direction right exitAt 46.45s exitDuration 480ms ease power3.out)
}

exportIcon {
  center
  layer hero
  width 250
  x -430
  y 8
  opacity 0
  scale 1
  shadow 32
  animation dynamicSlide(delay 46.85s duration 800ms direction right distance 140 exitAt 53.65s exitDuration 500ms ease power3.out)
}

finalLogo {
  center
  layer hero
  width 190
  y -82
  opacity 0
  scale 1
  shadow 32
  animation maskReveal(delay 58.6s duration 750ms direction down exitAt 60.75s exitDuration 250ms ease power3.out)
}

text idea {
  value "You have the idea."
  center
  layer text
  y -82
  size 78
  weight 740
  color #f7f8fb
  opacity 1
  textAnimation keynoteText(split words stagger 100ms duration 800ms delay 150ms ease power3.out exitAt 2.85s exitDuration 500ms)
}

text content {
  value "You have the content."
  center
  layer text
  y 18
  size 54
  weight 520
  color rgba(235,239,247,.68)
  opacity 1
  textAnimation keynoteText(split words stagger 85ms duration 700ms delay 1.45s ease power3.out exitAt 2.85s exitDuration 500ms)
}

text tension {
  value "But bringing that idea to life can sometimes"
  center
  layer text
  y -58
  size 48
  weight 700
  color #f7f8fb
  opacity 1
  textAnimation keynoteText(split words stagger 55ms duration 850ms delay 2.95s ease power3.out exitAt 7s exitDuration 550ms)
}

text tensionLine2 {
  value "take more time than the idea itself."
  center
  layer text
  y 30
  size 48
  weight 700
  color #f7f8fb
  opacity 1
  textAnimation keynoteText(split words stagger 55ms duration 800ms delay 3.45s ease power3.out exitAt 7s exitDuration 550ms)
}

text brandTitle {
  value "Motionly is a lightweight motion editor"
  center
  layer text
  x 310
  y -126
  size 46
  weight 740
  color #ffffff
  opacity 1
  textAnimation keynoteText(split words stagger 75ms duration 850ms delay 7.75s ease power3.out exitAt 14.15s exitDuration 500ms)
}

text brandCopy {
  value "built for creators and developers who want a simpler way"
  center
  layer text
  x 310
  y -38
  size 30
  weight 520
  color rgba(235,239,247,.78)
  opacity 1
  textAnimation keynoteText(split words stagger 60ms duration 700ms delay 10s ease power3.out exitAt 14.15s exitDuration 500ms)
}

text brandLine3 {
  value "to create polished animation."
  center
  layer text
  x 310
  y 42
  size 34
  weight 450
  color #7cf7c5
  opacity 1
  textAnimation keynoteText(split words stagger 65ms duration 650ms delay 11.6s ease power3.out exitAt 14.15s exitDuration 500ms)
}

text sourceTitle {
  value "Create motion graphics using a simple, editable format."
  center
  layer text
  x 330
  y -78
  size 42
  weight 730
  color #f7f8fb
  opacity 1
  textAnimation keynoteText(split words stagger 130ms duration 800ms delay 14.65s ease power3.out exitAt 20.1s exitDuration 480ms)
