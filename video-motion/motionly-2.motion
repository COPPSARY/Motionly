  value "Define your scenes, control timing, preview your changes,"
  center
  layer text
  y -342
  size 40
  weight 730
  color #f7f8fb
  opacity 1
  textAnimation keynoteText(split words stagger 110ms duration 800ms delay 20.55s ease power3.out exitAt 23.4s exitDuration 480ms)
